{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for newdb desktop app",
  "windows": ["main", "newdb-log-window", "newdb-cli-terminal"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:event:allow-listen"
  ]
