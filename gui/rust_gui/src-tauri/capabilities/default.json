{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for StructDB desktop app",
  "windows": ["main", "structdb-log-window", "structdb-cli-terminal"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:event:allow-listen"
  ]
}
