{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "newdb-rust-vue-gui",
  "version": "0.1.0",
  "identifier": "com.newdb.rustvuegui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "newdb Rust + Vue GUI",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "bin/newdb_demo.exe",
      "bin/newdb_perf.exe",
      "bin/libnewdb.dll",
      "bin/libgcc_s_seh-1.dll",
      "bin/libwinpthread-1.dll",
      "bin/libstdc++-6.dll"
    ]
  }
}
